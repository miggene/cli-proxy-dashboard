# =============================================================================
# cli-proxy-dashboard Docker Compose 环境变量配置
# 使用方法：cp .env.example .env，然后编辑 .env
# =============================================================================

# ---- CLIProxyAPI ----

# 使用预构建镜像（默认），或指定本地镜像名（本地构建时使用）
# CLI_PROXY_IMAGE=eceasy/cli-proxy-api:latest

# CLIProxyAPI 对外暴露的端口（默认 8317）
# CPA_API_PORT=8317

# config.yaml 路径（相对于 docker-compose.yml 所在目录）
CLI_PROXY_CONFIG_PATH=./CLIProxyAPI/config.yaml

# 认证文件目录（OAuth 登录后保存的 .json 文件）
CLI_PROXY_AUTH_PATH=./auths

# 日志目录
CLI_PROXY_LOG_PATH=./logs

# ---- CPA-Dashboard ----

# Dashboard 对外暴露的端口（默认 5000）
# DASHBOARD_PORT=5000

# CLIProxyAPI Management API Key（需与 config.yaml 中的 remote-management.secret-key 一致）
# 留空则使用"本地文件模式"，直接读取 auths/ 目录
CPA_MANAGEMENT_KEY=

# 是否开启 Flask 调试模式（生产环境保持 false）
# WEBUI_DEBUG=false
